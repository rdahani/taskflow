# TaskFlow — racine du site (Apache)
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Si l'app est dans un sous-dossier, laisser tel quel ; sinon optionnel :
  # RewriteBase /taskflow/
</IfModule>

# Pas de listing des répertoires
Options -Indexes

# Fichiers sensibles à la racine et sous-dossiers (le dossier config/ est aussi protégé séparément)
<FilesMatch "\.(sql|md|example|log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
