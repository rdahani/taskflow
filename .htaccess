# TaskFlow — racine du site (Apache)
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Si l'app est dans un sous-dossier, laisser tel quel ; sinon optionnel :
  # RewriteBase /taskflow/
</IfModule>

# Pas de listing des répertoires
Options -Indexes

# Fichiers sensibles à la racine et sous-dossiers
<FilesMatch "\.(sql|md|example|log|env|bak|swp|local\.php|ini|conf|yml|yaml|json|lock|xml)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Bloquer l'accès aux fichiers cachés (.git, .env, etc.)
<IfModule mod_rewrite.c>
  RewriteRule (^|/)\.(?!well-known) - [F,L]
</IfModule>

# Empêcher l'exécution de PHP dans le dossier uploads
<IfModule mod_rewrite.c>
  RewriteRule ^uploads/.*\.(php|phtml|phar|cgi|pl|py|sh)$ - [F,L]
</IfModule>
